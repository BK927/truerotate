<UserControl
    x:Class="TrueRotate.SettingCard"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    AutomationProperties.Name="{x:Bind Header, Mode=OneWay}">

    <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="1" CornerRadius="4" Padding="16,12" MinHeight="64">
        <Grid ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" VerticalAlignment="Center" Spacing="2">
                <TextBlock Text="{x:Bind Header, Mode=OneWay}"
                           Style="{StaticResource BodyStrongTextBlockStyle}"
                           TextWrapping="Wrap"/>
                <TextBlock Text="{x:Bind Description, Mode=OneWay}"
                           Visibility="{x:Bind HasText(Description), Mode=OneWay}"
                           Style="{StaticResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           TextWrapping="Wrap"/>
            </StackPanel>

            <ContentPresenter Grid.Column="1"
                              Content="{x:Bind ActionContent, Mode=OneWay}"
                              VerticalAlignment="Center" HorizontalAlignment="Right"/>
        </Grid>
    </Border>
</UserControl>
